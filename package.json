{
  "type": "module",
  "scripts": {
    "scaffold": "tsx scripts/scaffold.ts",
    "validate": "tsx scripts/build.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint scripts/",
    "lint:fix": "eslint scripts/ --fix",
    "format": "prettier --write scripts/",
    "format:check": "prettier --check scripts/",
    "prepare": "husky",
    "release": "tsx scripts/release.ts",
    "release:tag": "tsx scripts/release-tag.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "gray-matter": "^4.0.3",
    "semver": "^7.7.4"
  },
  "lint-staged": {
    "scripts/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "ai-skills-manager": "^1.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tsx": "^4.7.0",
    "vitest": "^3.2.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.52.0"
  }
}
